{
  "name": "vue-out-of-the-box-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "type-check": "vue-tsc --build --force",
    "build-only": "vite build",
    "lint": "npm run lint:script && npm run lint:style && npm run lint:markup",
    "lint:script": "eslint . --ext .js,.cjs,.ts,.vue",
    "lint:style": "stylelint **/*.{css,scss,vue} --ignore-path .stylelintignore",
    "lint:markup": "vue-tsc --noEmit -p tsconfig.tests.json",
    "lint:staged": "lint-staged",
    "test": "npm run test:coverage",
    "test:coverage": "vitest run --coverage",
    "generate:openapi": "orval"
  },
  "dependencies": {
    "@unleash/proxy-client-vue": "^0.1.6",
    "@vuepic/vue-datepicker": "^14.0.0",
    "@vueuse/core": "^14.3.0",
    "axios": "^1.18.0",
    "date-fns": "^4.4.0",
    "dompurify": "^3.4.11",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "tabulator-tables": "^6.5.1",
    "vue": "^3.5.38",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.13.2",
    "@types/tabulator-tables": "^6.3.4",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.8.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "@vuelidate/core": "^2.0.3",
    "@vuelidate/validators": "^2.0.4",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.9.2",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "npm-run-all2": "^8.0.4",
    "orval": "^7.13.2",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "sass-embedded": "^1.100.0",
    "stylelint": "^17.13.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "vite": "^8.0.16",
    "vite-plugin-vue-devtools": "^8.1.3",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  },
  "lint-staged": {
    "*.{js,cjs,ts,vue}": "eslint --fix",
    "*.{css,scss,vue}": "stylelint --fix",
    "*": "prettier -w -u"
  }
}
